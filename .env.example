# Required for product analysis and direct image generation.
OPENAI_API_KEY=

# Strongly recommended on Vercel so other visitors cannot spend your API budget.
SITE_ACCESS_PASSWORD=

# Optional model overrides.
OPENAI_MODEL=gpt-5.6
OPENAI_IMAGE_MODEL=gpt-image-2

# Personal cross-device project storage (Supabase).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_OWNER_EMAIL=
